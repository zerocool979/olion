generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                    @id @default(uuid())
  email                 String                    @unique
  password              String?
  googleId              String?                   @unique
  role                  Role                      @default(USER)
  isVerifiedExpert      Boolean                   @default(false)
  isBanned              Boolean                   @default(false)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  comments              Comment[]
  conversations         ConversationParticipant[]
  discussions           Discussion[]
  expertApplications    ExpertApplication[]
  following             Follow[]                  @relation("UserFollows")
  followers             Follow[]                  @relation("UserFollowedBy")
  messagesSent          Message[]
  notificationsSent     Notification[]            @relation("NotificationActor")
  notificationsReceived Notification[]            @relation("NotificationRecipient")
  profile               Profile?
  reportsMade           Report[]                  @relation("ReporterUser")
  reportedBy            Report[]                  @relation("ReportedUser")
  reputations           ReputationLog[]
  badges                UserBadge[]
  votes                 Vote[]
  bookmarks             Bookmark[]
  liaDocuments          Document[]
  liaChatLogs           ChatLog[]

  @@index([role])
  @@index([isBanned])
  @@index([createdAt(sort: Desc)])
}

model Profile {
  id            String   @id @default(uuid())
  userId        String   @unique
  username      String   @unique
  bio           String?
  avatarUrl     String?
  avatarBorder  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowedBy", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Category {
  id          String       @id @default(uuid())
  name        String       @unique
  slug        String       @unique
  description String?
  color       String?
  borderColor String?
  parentId    String?
  parent      Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]   @relation("CategoryTree")
  discussions Discussion[]

  @@index([slug])
  @@index([parentId])
}

model Discussion {
  id         String          @id @default(uuid())
  title      String
  content    String
  mode       DiscussionMode
  discipline DisciplineLevel
  viewCount  Int             @default(0)
  isHidden   Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  userId     String?
  categoryId String
  comments   Comment[]
  category   Category        @relation(fields: [categoryId], references: [id])
  user       User?           @relation(fields: [userId], references: [id])
  tags       DiscussionTag[]
  reports    Report[]
  votes      Vote[]
  bookmarks  Bookmark[]

  @@index([userId])
  @@index([categoryId])
  @@index([isHidden])
  @@index([createdAt(sort: Desc)])
  @@index([mode])
}

model Bookmark {
  id           String     @id @default(uuid())
  createdAt    DateTime   @default(now())
  userId       String
  discussionId String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@index([userId])
  @@index([discussionId])
}

model Comment {
  id           String     @id @default(uuid())
  content      String
  isHidden     Boolean    @default(false)
  parentId     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userId       String?
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parent       Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]  @relation("CommentReplies")
  user         User?      @relation(fields: [userId], references: [id])
  reports      Report[]
  votes        Vote[]

  @@index([discussionId])
  @@index([userId])
  @@index([parentId])
}

model Vote {
  id           String      @id @default(uuid())
  value        Int
  createdAt    DateTime    @default(now())
  userId       String
  discussionId String?
  commentId    String?
  comment      Comment?    @relation(fields: [commentId], references: [id], onDelete: Cascade)
  discussion   Discussion? @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@unique([userId, commentId])
  @@index([discussionId])
  @@index([commentId])
}

model Report {
  id           String       @id @default(uuid())
  reason       String
  status       ReportStatus @default(PENDING)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  reporterId   String
  discussionId String?
  commentId    String?
  targetUserId String?
  comment      Comment?     @relation(fields: [commentId], references: [id], onDelete: Cascade)
  discussion   Discussion?  @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  reporter     User         @relation("ReporterUser", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser   User?        @relation("ReportedUser", fields: [targetUserId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model ReputationLog {
  id        String   @id @default(uuid())
  point     Int
  reason    String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
}

model Tag {
  id          String          @id @default(uuid())
  name        String          @unique
  slug        String          @unique
  discussions DiscussionTag[]

  @@index([slug])
}

model DiscussionTag {
  discussionId String
  tagId        String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  tag          Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([discussionId, tagId])
  @@index([tagId])
}

model Notification {
  id           String           @id @default(uuid())
  type         NotificationType
  message      String?
  read         Boolean          @default(false)
  createdAt    DateTime         @default(now())
  userId       String
  actorId      String?
  discussionId String?
  commentId    String?
  actor        User?            @relation("NotificationActor", fields: [actorId], references: [id])
  user         User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
}

model Conversation {
  id           String                    @id @default(uuid())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  // Kunci unik pasangan 2 partisipan (userId diurut lalu digabung), dipakai
  // via upsert supaya percakapan 1:1 antara dua orang yang sama TIDAK
  // PERNAH bisa duplikat, bahkan kalau ada race condition (dua klik cepat).
  pairKey      String?                   @unique
  participants ConversationParticipant[]
  messages     Message[]

  @@index([updatedAt(sort: Desc)])
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(uuid())
  content        String?      // opsional — pesan bisa berupa lampiran saja tanpa teks
  attachmentUrl  String?      // URL Cloudinary (foto/file persisten, bukan disk lokal)
  attachmentType String?      // 'image' | 'file'
  attachmentName String?      // nama file asli, dipakai untuk lampiran non-gambar
  createdAt      DateTime     @default(now())
  conversationId String
  senderId       String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt(sort: Desc)])
}

model Badge {
  id          String      @id @default(uuid())
  slug        String      @unique
  name        String
  description String
  icon        String
  threshold   Int         @default(0)
  users       UserBadge[]

  @@index([threshold])
}

model UserBadge {
  id       String   @id @default(uuid())
  earnedAt DateTime @default(now())
  userId   String
  badgeId  String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model ExpertApplication {
  id          String            @id @default(uuid())
  field       String
  credentials String
  status      ApplicationStatus @default(PENDING)
  reviewNote  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

enum Role {
  USER
  EXPERT
  MODERATOR
  ADMIN
}

enum ReportStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum DiscussionMode {
  INFORMATIF
  KLARIFIKATIF
  EKSPLORATIF
  EVALUATIF
  ARGUMENTATIF
  PRAKTIS
  ANONYMOUS
  IDENTIFIED
}

enum DisciplineLevel {
  BEBAS
  RASIONAL
  AKADEMIK
  PROFESIONAL
}

enum NotificationType {
  FOLLOW
  COMMENT
  VOTE
  MENTION
  REPORT_RESOLVED
  SYSTEM
  REPLY
  EXPERT_VERIFIED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

// ═══════════════════════════════════════════════════════════════════════════
// LIA — Chatbot Knowledge Base (RAG: Retrieval-Augmented Generation)
// ═══════════════════════════════════════════════════════════════════════════
// Document: satu dokumen sumber (FAQ, panduan, dsb) yang di-ingest ke KB.
// Chunk: potongan teks dari Document + embedding-nya, dipakai untuk
//   pencarian kemiripan (cosine similarity) saat menjawab pertanyaan.
// ChatLog: riwayat tanya-jawab, dipakai untuk fitur "riwayat percakapan"
//   di widget serta audit/analitik ringan.

model Document {
  id        String   @id @default(uuid())
  title     String
  source    String? // nama file asli / label sumber, opsional
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String? // admin yang meng-upload — nullable, jaga-jaga akun dihapus
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  chunks    Chunk[]

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Chunk {
  id         String   @id @default(uuid())
  content    String
  // Embedding disimpan sebagai JSON string (array of floats, 384 dimensi
  // dari model all-MiniLM-L6-v2). PostgreSQL tanpa ekstensi pgvector masih
  // sanggup brute-force cosine similarity di JS untuk KB skala kecil-menengah
  // (ribuan chunk) — lihat services/lia/vectorStore.js.
  embedding  String
  chunkIndex Int
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([documentId])
}

model ChatLog {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sourceIds String // JSON array of chunk id yang dipakai sebagai konteks jawaban
  userId    String? // nullable — endpoint LIA boleh dipakai tanpa login
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}
