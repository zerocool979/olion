# =============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# Salin file ini menjadi ".env" lalu isi nilai sesuai environment Anda.
# JANGAN PERNAH commit file ".env" asli ke Git (sudah ada di .gitignore).
# =============================================================================

# --- Application ------------------------------------------------------------
APP_NAME="RAG Academic Chat"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_VERSION=0.1.0

# --- Logging ------------------------------------------------------------
LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_DIR=logs
LOG_ROTATION="10 MB"
LOG_RETENTION="14 days"

# =============================================================================
# Variabel berikut akan digunakan pada milestone lanjutan.
# Sudah didaftarkan di sini agar template konfigurasi tetap terpusat sejak awal,
# namun BELUM di-load/divalidasi oleh Settings pada Milestone 1.
# =============================================================================

# --- Milestone 6-7: Embedding & Vector DB -----------------------------------
# EMBEDDING_MODEL_NAME=
# VECTOR_DB_HOST=
# VECTOR_DB_PORT=
# VECTOR_DB_COLLECTION=

# --- Milestone 2 & 15: LLM (Base Model / Fine-tuned Model) ------------------
# LLM_PROVIDER: "mock" untuk dev/test tanpa GPU, "huggingface" untuk model sungguhan
LLM_PROVIDER=mock
LLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_DEVICE=auto
# WAJIB false di production - lihat penjelasan QUICK_DEMO_MODE di HuggingFaceLLMClient
LLM_QUICK_DEMO_MODE=true

# --- Milestone 11: Backend API ------------------------------------------------
# API_HOST=0.0.0.0
# API_PORT=8000
# API_SECRET_KEY=
